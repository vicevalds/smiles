<template id="card-template">
	<li class="group flex flex-col overflow-hidden border-2 border-accent">
		<figure class="flex flex-1 flex-col">
			<div
				data-svg
				class="flex aspect-square items-center justify-center p-1 [&_svg]:h-full [&_svg]:w-full"
			><span class="text-2xl">;(</span></div>
			<figcaption
				class="flex items-center gap-2 p-2 text-xs border-t border-accent font-mono"
			>
				<span data-name class="min-w-0 flex-1 truncate"></span>
				<span data-value class="shrink-0 tabular-nums text-gray-600"></span>
			</figcaption>
		</figure>
	</li>
</template>
