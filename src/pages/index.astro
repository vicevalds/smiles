---
import '@/styles/global.css'
import SmilesForm from '@/components/SmilesForm.astro'
import MoleculeCard from '@/components/MoleculeCard.astro'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Paste or upload SMILES strings and render 2D molecule structures in the browser."/>
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">
		<link rel="preload" href="/Geist%5Bwght%5D.woff2" as="font" type="font/woff2" crossorigin />
		<title>*.smi</title>
	</head>
	<body>
		<main class="flex py-6 px-4">
			<aside class="w-80 sticky top-6 self-start">
				<SmilesForm />
			</aside>
			<div class="flex-1 min-w-0">
				<section aria-labelledby="gallery-title" class="pl-4 mt-8">
					<h2 id="gallery-title" class="sr-only">Rendered molecules</h2>
					<ul id="gallery" class="grid grid-cols-5 gap-4"></ul>
				</section>

				<MoleculeCard />
			</div>
		</main>

		<script src="@/scripts/viewer.ts"></script>
	</body>
</html>
