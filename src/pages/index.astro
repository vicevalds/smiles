---
import '@/styles/global.css'
import SmilesForm from '@/components/SmilesForm.astro'
import MoleculeCard from '@/components/MoleculeCard.astro'
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="manifest" href="/site.webmanifest">
		<title>*.smi</title>
		<script is:inline src="/RDKit_minimal.js"></script>
	</head>
	<body>
		<main class="flex py-6 px-4">
			<aside class="w-80 sticky top-6 self-start">
				<SmilesForm />
			</aside>
			<div class="flex-1 min-w-0">
				<section aria-labelledby="gallery-title" class="pl-4 mt-8">
					<ul id="gallery" class="grid grid-cols-5 gap-4"></ul>
				</section>

				<MoleculeCard />
			</div>
		</main>

		<script>
			type RDKitMol = {
				is_valid: () => boolean
				get_svg: (w: number, h: number) => string
				delete: () => void
			}
			type RDKitModule = { get_mol: (smiles: string) => RDKitMol | null }

			declare global {
				interface Window {
					initRDKitModule: () => Promise<RDKitModule>
				}
			}

			const form = document.querySelector<HTMLFormElement>('#smiles-form')!
			const textarea = document.querySelector<HTMLTextAreaElement>('#smiles-text')!
			const fileInput = document.querySelector<HTMLInputElement>('#smiles-file')!
			const renderBtn = document.querySelector<HTMLButtonElement>('#render-btn')!
			const gallery = document.querySelector<HTMLUListElement>('#gallery')!
			const columns = document.querySelector<HTMLInputElement>('#columns')!
			const columnsValue = document.querySelector<HTMLSpanElement>('#columns-value')!
			const cardTemplate = document.querySelector<HTMLTemplateElement>('#card-template')!

			const columnClasses: Record<string, string> = {
				'2': 'grid-cols-2',
				'3': 'grid-cols-3',
				'4': 'grid-cols-4',
				'5': 'grid-cols-5',
				'6': 'grid-cols-6',
				'7': 'grid-cols-7',
				'8': 'grid-cols-8',
			}

			const applyColumns = () => {
				gallery.classList.remove(...Object.values(columnClasses))
				gallery.classList.add(columnClasses[columns.value])
				columnsValue.textContent = columns.value
			}
			columns.addEventListener('input', applyColumns)

			// Inicializa RDKit una sola vez y habilita el botón al estar listo.
			const rdkit = await window.initRDKitModule()
			renderBtn.disabled = false

			// Cada entrada: primer token = SMILES, resto = nombre opcional.
			const parseEntries = (text: string) =>
				text
					.split('\n')
					.map((line) => line.trim())
					.filter(Boolean)
					.map((line) => {
						const [smiles, ...rest] = line.split(/\s+/)
						return { smiles, name: rest.join(' ') }
					})

			const renderCard = ({ smiles, name }: { smiles: string; name: string }) => {
				const mol = rdkit.get_mol(smiles)
				const valid = !!mol && mol.is_valid()
				const label = name || smiles

				const card = cardTemplate.content.firstElementChild!.cloneNode(true) as HTMLLIElement

				card.querySelectorAll<HTMLElement>('[data-svg]').forEach((el) => {
					if (valid) {
						el.innerHTML = mol!.get_svg(300, 300)
					} else {
						el.textContent = 'NULL'
					}
				})

				// textContent escapa el contenido automáticamente.
				card.querySelectorAll<HTMLElement>('[data-name]').forEach((el) => {
					el.textContent = label
					el.title = label
				})

				mol?.delete()
				return card
			}

			form.addEventListener('submit', async (event) => {
				event.preventDefault()
				renderBtn.disabled = true

				let text = textarea.value
				const file = fileInput.files?.[0]
				if (file) text += '\n' + (await file.text())

				const entries = parseEntries(text)
				gallery.replaceChildren()

				if (entries.length === 0) {
					renderBtn.disabled = false
					return
				}

				// Renderiza por lotes en frames sucesivos para que las tarjetas
				// vayan apareciendo sobre la marcha sin bloquear la interfaz.
				const BATCH_SIZE = 12
				const nextFrame = () => new Promise(requestAnimationFrame)

				for (let i = 0; i < entries.length; i += BATCH_SIZE) {
					const fragment = document.createDocumentFragment()
					for (const entry of entries.slice(i, i + BATCH_SIZE)) {
						fragment.append(renderCard(entry))
					}
					gallery.append(fragment)
					await nextFrame()
				}

				renderBtn.disabled = false
			})
		</script>
	</body>
</html>
